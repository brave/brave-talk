{
  "name": "brave-talk-app",
  "version": "0.1.0",
  "description": "private and unlimited video calling by Brave",
  "private": true,
  "type": "module",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "build": "NODE_ENV=production webpack --config webpack.config.cjs --mode production",
    "format": "prettier --write .",
    "lint": "eslint src/",
    "start": "webpack serve --config webpack.config.cjs --mode development",
    "test": "jest",
    "prepare": "husky",
    "check": "pnpm run /^check:.*/",
    "check:build": "tsc",
    "check:audit": "pnpm audit --ignore-registry-errors",
    "check:lint": "eslint src/",
    "check:format": "prettier --check ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brave/brave-talk.git"
  },
  "homepage": "https://github.com/brave/brave-talk#readme",
  "devDependencies": {
    "@brave-intl/skus-sdk": "0.1.3",
    "@eslint/js": "^9.39.2",
    "@types/jest": "30.0.0",
    "@types/node": "^24.12.0",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "copy-webpack-plugin": "12.0.2",
    "css-loader": "6.11.0",
    "css-minimizer-webpack-plugin": "6.0.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "html-webpack-plugin": "5.6.7",
    "husky": "9.1.7",
    "jest": "30.3.0",
    "lint-staged": "15.5.2",
    "mini-css-extract-plugin": "2.10.2",
    "prettier": "3.8.3",
    "style-loader": "3.3.4",
    "svgo-loader": "4.0.0",
    "ts-jest": "29.4.9",
    "ts-loader": "9.5.7",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.0",
    "webpack": "5.106.2",
    "webpack-cli": "5.1.4",
    "webpack-dev-server": "5.2.3"
  },
  "dependencies": {
    "@brave/leo": "github:brave/leo#b0d5f184aee1862a37c3bd4dfe854fae5c784daa",
    "@emotion/react": "11.14.0",
    "@types/dom-screen-wake-lock": "1.0.3",
    "i18next": "23.16.8",
    "jest-environment-jsdom": "30.3.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-i18next": "14.1.3"
  },
  "lint-staged": {
    "*": "prettier --ignore-unknown --write",
    "*.ts?(x)": "eslint"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
